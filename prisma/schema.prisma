generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TicketPriority {
  low
  medium
  high
  urgent
}

model Ticket {
  id            String   @id @default(cuid())
  title         String
  description   String?
  priority      TicketPriority?
  createdAt     DateTime @default(now())
}
