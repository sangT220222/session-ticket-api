generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TicketPriority {
  low
  medium
  high
  urgent
}

enum TicketStatus {
  todo
  in_progress
  completed
}

model Ticket {
  id            String   @id @default(cuid())
  title         String
  description   String?
  priority      TicketPriority?
  status        TicketStatus?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
}

model User{
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
